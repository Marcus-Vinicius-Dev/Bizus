Definir o modelo que representa os dados a manipular 
meu_projeto\meu_app\models.py
from django.db import models

class Item(models.Model):
    nome = models.CharField(max_length=100)  # Nome do item
    descricao = models.TextField()  # Descrição do item
    preco = models.DecimalField(max_digits=10, decimal_places=2)  # Preço do item

    def __str__(self):
        return self.nome
